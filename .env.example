# KaijiBot Simplify .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.kaijibot/.env` (for systemd/launchd).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence (highest -> lowest):
# process env, ./.env, ~/.kaijibot/.env, then kaijibot.json `env` block.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
KAIJIBOT_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# KAIJIBOT_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# KAIJIBOT_STATE_DIR=~/.kaijibot
# KAIJIBOT_CONFIG_PATH=~/.kaijibot/kaijibot.json
# KAIJIBOT_HOME=~

# -----------------------------------------------------------------------------
# Z.AI (智谱 GLM) — default LLM provider
# -----------------------------------------------------------------------------
ZAI_API_KEY=your-zai-api-key
# Get your key at: https://open.bigmodel.cn/

# -----------------------------------------------------------------------------
# Feishu (飞书) — default messaging channel
# -----------------------------------------------------------------------------
# FEISHU_APP_ID=cli_xxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# These can also be set via: kaijibot config set channels.feishu.appId "xxx"

# -----------------------------------------------------------------------------
# OpenAI compatible (optional, as fallback provider)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...
